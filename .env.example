# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ml_inference
DB_USER=ml_user
DB_PASSWORD=ml_password
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL=300

# ML Model
MODEL_PATH=./models/classifier.joblib

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
